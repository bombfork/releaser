# Generated by releaser. Do not edit by hand — re-run `releaser generate`.
#
# This workflow maintains the pending-release pull request: it computes the
# next version from the commits since the last release and keeps a single
# open PR carrying the draft release notes and the version-file bumps.
#
# When the PR is merged, the publish workflow takes over.
#
# Triggered automatically on every push to the default branch, and
# manually via workflow_dispatch (with optional dry-run).

name: releaser pending release

on:
  push:
    branches:
      - << .DefaultBranch >>
  workflow_dispatch:
    inputs:
      dry_run:
        description: 'Run without side effects (no commits, no branch push, no PR ops)'
        type: boolean
        default: false

permissions:
  contents: write
  pull-requests: write

jobs:
  maintain:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0
<<- range .SetupSteps >>
<< . | indent 6 >>
<<- end >>
      - name: Maintain pending-release pull request
        uses: bombfork/releaser@<< .ActionRef >>
        with:
          command: release prepare ${{ inputs.dry_run && '--dry-run' || '' }}
          app-id: ${{ vars.RELEASER_APP_ID }}
          app-installation-id: ${{ vars.RELEASER_APP_INSTALLATION_ID }}
          app-private-key: ${{ secrets.RELEASER_APP_PRIVATE_KEY }}
