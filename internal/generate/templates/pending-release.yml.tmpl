name: releaser pending release

on:
  push:
    branches:
      - main

permissions:
  contents: write
  pull-requests: write

jobs:
  maintain:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
<<- range .SetupSteps >>
<< . | indent 6 >>
<<- end >>
      - name: Maintain pending-release pull request
        uses: bombfork/releaser@<< .ActionRef >>
        with:
          command: release prepare
          github-token: ${{ secrets.GITHUB_TOKEN }}
