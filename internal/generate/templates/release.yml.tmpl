# Generated by releaser. Do not edit by hand — re-run `releaser generate`.
#
# This workflow drives the release process. A first step inspects the
# head commit and chooses between two modes:
#
#   - "release publish": when the head commit looks like the merge of
#     the pending-release pull request (default merge-commit message
#     contains "from <owner>/<release-branch>", or the head commit is a
#     "chore(release): prepare vX.Y.Z" bump under squash / rebase
#     strategies). Publishes the release.
#   - "release prepare": otherwise. Keeps the pending-release pull
#     request in sync with the unreleased commits on the default branch.
#
# Triggers: push to the default branch, plus workflow_dispatch with a
# mode override (auto / prepare / publish) and an optional dry-run.
#
# Auto-detection caveats — when the head commit doesn't fit either
# signal above, the workflow falls back to "release prepare". Use
# workflow_dispatch with an explicit mode to force the other command.
# Known cases:
#   - Extra commits pushed onto the release branch before merging shift
#     HEAD off the bump commit; under rebase merging, only the
#     "chore(release): prepare v" prefix would have matched, so the
#     auto-detect picks prepare.
#   - Customized squash-merge messages that drop both the chore prefix
#     and the "from .../<branch>" substring.
#   - release.branch_name changed while a pending-release PR was open.
#
# Manual fallback: workflow_dispatch with mode=publish (or mode=prepare).

name: releaser

on:
  push:
    branches:
      - << .DefaultBranch >>
  workflow_dispatch:
    inputs:
      mode:
        description: 'Force a specific mode (auto detects from the head commit)'
        type: choice
        default: auto
        options:
          - auto
          - prepare
          - publish
      dry_run:
        description: 'Run without side effects (no commits, branch push, PR ops, release creation, builds, or asset uploads)'
        type: boolean
        default: false

permissions:
  contents: write
  pull-requests: write

jobs:
  release:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0
<<- range .SetupSteps >>
<< . | indent 6 >>
<<- end >>
      - name: Determine mode
        id: mode
        env:
          MODE_INPUT: ${{ inputs.mode }}
          HEAD_MSG: ${{ github.event.head_commit.message }}
          RELEASE_BRANCH: << .BranchName >>
        shell: bash
        run: |
          set -euo pipefail
          case "${MODE_INPUT:-auto}" in
            prepare) cmd="release prepare" ;;
            publish) cmd="release publish" ;;
            *)
              msg="${HEAD_MSG:-}"
              if [[ -z "$msg" ]]; then
                msg=$(git log -1 --pretty=%B HEAD)
              fi
              first_line=$(printf '%s\n' "$msg" | head -n1)
              prepare_re='^chore\(release\): prepare v'
              branch_re='from [^[:space:]/]+/'"${RELEASE_BRANCH}"'([[:space:]]|$)'
              if [[ "$first_line" =~ $prepare_re ]] || [[ "$first_line" =~ $branch_re ]]; then
                cmd="release publish"
              else
                cmd="release prepare"
              fi
              ;;
          esac
          echo "command=$cmd" >> "$GITHUB_OUTPUT"
          echo "Selected command: $cmd"

      - name: Run releaser
        uses: bombfork/releaser@<< .ActionRef >>
        with:
          command: ${{ steps.mode.outputs.command }} ${{ inputs.dry_run && '--dry-run' || '' }}
          app-id: ${{ vars.RELEASER_APP_ID }}
          app-installation-id: ${{ vars.RELEASER_APP_INSTALLATION_ID }}
          app-private-key: ${{ secrets.RELEASER_APP_PRIVATE_KEY }}
