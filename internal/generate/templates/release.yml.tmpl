# Generated by bombfork releaser. Do not edit by hand — re-run `releaser generate`.
#
# This workflow drives the release process. A first step inspects the
# head commit and chooses between two modes:
#
#   - "release publish": when the head commit looks like the merge of
#     the pending-release pull request. Two signals are checked:
#       * the message contains a "chore(release): prepare vX.Y.Z" line
#         (covers rebase merge — that commit becomes HEAD; and squash
#         merge — the line appears in the squash body as a bullet);
#       * the first line contains "from <owner>/<release-branch>"
#         (covers the default merge-commit strategy).
#     Publishes the release.
#   - "release prepare": otherwise. Keeps the pending-release pull
#     request in sync with the unreleased commits on the default branch.
#
# Triggers: push to the default branch, plus workflow_dispatch with a
# mode override (auto / prepare / publish) and an optional dry-run.
#
# Auto-detection caveats — when neither signal matches, the workflow
# falls back to "release prepare". Use workflow_dispatch with an
# explicit mode to force the other command. Known cases:
#   - Rebase merge with extra commits on top of the bump commit: HEAD
#     becomes the extra commit and neither signal matches.
#   - Customized squash-merge messages that strip the body (the body
#     normally carries the original "chore(release): prepare v" commit,
#     which is the squash signal).
#   - release.branch_name changed while a pending-release PR was open.

name: releaser

on:
  push:
    branches:
      - << .DefaultBranch >>
  workflow_dispatch:
    inputs:
      mode:
        description: 'Force a specific mode (auto detects from the head commit)'
        type: choice
        default: auto
        options:
          - auto
          - prepare
          - publish
      dry_run:
        description: 'Run without side effects (no commits, branch push, PR ops, release creation, builds, or asset uploads)'
        type: boolean
        default: false

permissions:
  contents: write
  pull-requests: write

jobs:
  release:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6
        with:
          fetch-depth: 0
<<- range .SetupSteps >>
<< . | indent 6 >>
<<- end >>
      - name: Determine mode
        id: mode
        env:
          MODE_INPUT: ${{ inputs.mode }}
          HEAD_MSG: ${{ github.event.head_commit.message }}
          RELEASE_BRANCH: << .BranchName >>
        shell: bash
        run: |
          set -euo pipefail
          case "${MODE_INPUT:-auto}" in
            prepare) cmd="release prepare" ;;
            publish) cmd="release publish" ;;
            *)
              msg="${HEAD_MSG:-}"
              if [[ -z "$msg" ]]; then
                msg=$(git log -1 --pretty=%B HEAD)
              fi
              first_line=$(printf '%s\n' "$msg" | head -n1)
              # Match the prepare-commit subject anywhere in the message
              # (with an optional leading "* " so squash-merge body bullets
              # also count), and the branch substring on the first line
              # (default merge-commit message format).
              branch_re='from [^[:space:]/]+/'"${RELEASE_BRANCH}"'([[:space:]]|$)'
              if printf '%s\n' "$msg" | grep -qE '^(\* )?chore\(release\): prepare v' \
                || [[ "$first_line" =~ $branch_re ]]; then
                cmd="release publish"
              else
                cmd="release prepare"
              fi
              ;;
          esac
          echo "command=$cmd" >> "$GITHUB_OUTPUT"
          echo "Selected command: $cmd"

      - name: Run releaser
        uses: bombfork/releaser@<< .ActionRef >>
        with:
          version: << .ActionVersion >>
          command: ${{ steps.mode.outputs.command }} ${{ inputs.dry_run && '--dry-run' || '' }}
          app-id: ${{ vars.RELEASER_APP_ID }}
          app-installation-id: ${{ vars.RELEASER_APP_INSTALLATION_ID }}
          app-private-key: ${{ secrets.RELEASER_APP_PRIVATE_KEY }}
